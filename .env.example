# ─── Postgres (relational: users, orgs, sites, billing) ───
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=seyr
POSTGRES_PASSWORD=seyr
POSTGRES_DB=seyr
DATABASE_URL=postgresql://seyr:seyr@localhost:5432/seyr

# ─── ClickHouse (event store) ───
CLICKHOUSE_URL=http://localhost:8123
# Native protocol address used by the Go ingestor (clickhouse-go).
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_USER=seyr
CLICKHOUSE_PASSWORD=seyr
CLICKHOUSE_DB=seyr

# ─── Ingestor ───
INGESTOR_PORT=4000
# Daily-rotating salt is generated at runtime; this seeds it in dev only.
INGEST_SALT_SECRET=change-me-in-prod

# ─── Dashboard ───
PUBLIC_INGEST_HOST=http://localhost:4000
ORIGIN=http://localhost:5173
