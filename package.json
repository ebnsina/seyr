{
  "name": "seyr",
  "version": "0.0.0",
  "private": true,
  "description": "Privacy-first, cookieless web analytics — a clean, fast alternative to Google Analytics.",
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,svelte,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,svelte,js,json,md}\"",
    "infra:up": "docker compose --env-file .env -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose --env-file .env -f infra/docker-compose.yml down",
    "ingestor:dev": "cd apps/ingestor && go run ./cmd/ingestor",
    "ingestor:build": "cd apps/ingestor && go build -o bin/ingestor ./cmd/ingestor",
    "ingestor:test": "cd apps/ingestor && go test ./..."
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
